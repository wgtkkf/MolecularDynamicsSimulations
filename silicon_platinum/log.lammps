# -----------------------------------------------------------------------------
# LAMMPS Input File: Silicon-Platinum (Si-Pt) Interfacial Thermal Conductance (ITC)
# Method: Direct NEMD via Temperature Gradient (Langevin Thermostats)
# -----------------------------------------------------------------------------

# --- User-Defined Variables ---
# Set the temperature for the Silicon (Hot) side. Change this for your two scenarios.
variable                T_HOT_SIDE equal 305.0    # Use 305.0 or 470.0 (K)
WARNING: Detected non-ASCII characters in input. Will try to continue by replacing with ASCII equivalents where known. (src/input.cpp:431)
variable                T_COLD_SIDE equal 300.0 # Platinum (K)

# --- 1. Initialization and System Definition ---
units                      metal                      # eV, Angstrom, ps, bar
dimension              3
boundary                p p p                      # Periodic in all directions
atom_style            atomic

# --- 2. Structure Generation and Interface Creation ---

# NOTE: Si (a=5.43A, Diamond) and Pt (a=3.92A, FCC) have severe lattice mismatch.
# For a TEMPLATE, we assume a compromise lattice constant (e.g., 4.5A) and rely on NPT
# to relax the extreme strain, but a complex supercell is ideal for real research.
lattice                  fcc 4.5                  # Compromise lattice constant
Lattice spacing in x,y,z = 4.5000000 4.5000000 4.5000000
region                    box block 0 10 0 10 0 80    # Elongated in Z for heat flow
create_box            2 box                                          # 2 atom types
Created orthogonal box = (0.0000000 0.0000000 0.0000000) to (45.000000 45.000000 360.00000)
  1 by 1 by 8 MPI processor grid

# Create Silicon in the first half (Z<40)
region                    si_block block INF INF INF INF 0 40
create_atoms        1 region si_block
Created 16200 atoms
  using lattice units in orthogonal box = (0.0000000 0.0000000 0.0000000) to (45.000000 45.000000 360.00000)
  create_atoms CPU = 0.001 seconds
group                      si_atoms region si_block
16200 atoms in group si_atoms

# Two atom types: 1 = Si (Hot), 2 = Pt (Cold)
mass                        1 28.0855              # Silicon mass
mass                        2 195.084              # Platinum mass

# Create Platinum in the second half (Z>40)
region                    pt_block block INF INF INF INF 40 INF
create_atoms        2 region pt_block
Created 16000 atoms
  using lattice units in orthogonal box = (0.0000000 0.0000000 0.0000000) to (45.000000 45.000000 360.00000)
  create_atoms CPU = 0.000 seconds
group                      pt_atoms region pt_block
16200 atoms in group pt_atoms

# Define all atoms and the bulk region
group                      all_atoms union si_atoms pt_atoms
32200 atoms in group all_atoms

# --- 3. Potential Definition (Ternary EAM) ---
pair_style            eam/alloy
# IMPORTANT: Use a DUAL-ELEMENT (Si-Pt) EAM potential file here.
# You must source this file from a reliable database or publication.
pair_coeff            * * SiPt.eam.alloy Si Pt
