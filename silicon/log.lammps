## 1. Initialization
units        metal              # eV, Angstrom, ps, bar
dimension    3
boundary     p p p              # Periodic in all directions
atom_style   atomic

# --- 2. Structure Generation (<100> Orientation) ---
lattice      diamond 5.431      # Si Lattice Parameter
Lattice spacing in x,y,z = 5.4310000 5.4310000 5.4310000
region       box block 0 10 0 10 0 80 # Elongated in Z for heat flow (Lx=10, Ly=10, Lz=80)
create_box   1 box
Created orthogonal box = (0.0000000 0.0000000 0.0000000) to (54.310000 54.310000 434.48000)
  1 by 1 by 8 MPI processor grid
create_atoms 1 box
Created 64000 atoms
  using lattice units in orthogonal box = (0.0000000 0.0000000 0.0000000) to (54.310000 54.310000 434.48000)
  create_atoms CPU = 0.001 seconds
mass         1 28.0855

# --- CREATE INTERFACE (Sigma 5 Twist Grain Boundary) ---
# Creates a grain boundary by rotating the right half of the crystal
region           right_half block INF INF INF INF 40 INF
group            right_atoms region right_half
32000 atoms in group right_atoms
#displace_atoms   right_atoms rotate 5 5 40 0 0 1 36.87 # Twist around Z-axis (36.87 deg for Sigma 5)
displace_atoms   right_atoms rotate 5 5 40 0 0 1 0 # bulk thermal conductance
Displacing atoms ...

# --- INSERT FOR VISUALIZATION ---
write_data initial_structure.lammpsdata
