# -----------------------------------------------------------------------------
# LAMMPS Input File: Thermal Conductance Across a Vacuum Gap
# -----------------------------------------------------------------------------

# --- 1. USER INPUT VARIABLES ---
variable        G_SIZE equal 5.0
variable        T_HOT equal 305.0
variable        T_COLD equal 300.0
variable        MAT_SETUP string "Si_Si"
variable        POT_FILE string "Si.sw"

# --- 2. Initialization ---
units           metal
dimension       3
boundary        p p p
atom_style      atomic

# --- 3. Material Logic ---
if "${MAT_SETUP} == Si_Si" then   "variable LATTICE_TYPE string diamond"   "variable LATTICE_CONST equal 5.431"   "variable M1 equal 28.0855"   "variable M2 equal 28.0855"
variable LATTICE_TYPE string diamond
variable LATTICE_CONST equal 5.431
variable M1 equal 28.0855
variable M2 equal 28.0855
if "${MAT_SETUP} == Au_Au" then   "variable LATTICE_TYPE string fcc"   "variable LATTICE_CONST equal 4.08"   "variable M1 equal 196.9665"   "variable M2 equal 196.9665"
if "${MAT_SETUP} == Si_Pt" then   "variable LATTICE_TYPE string fcc"   "variable LATTICE_CONST equal 4.5"   "variable M1 equal 28.0855"   "variable M2 equal 195.084"

# --- 4. Structure Generation ---
lattice         ${LATTICE_TYPE} ${LATTICE_CONST}
lattice         diamond ${LATTICE_CONST}
lattice         diamond 5.431
Lattice spacing in x,y,z = 5.4310000 5.4310000 5.4310000

variable        z2_start equal 40.0+(${G_SIZE}/${LATTICE_CONST})
variable        z2_start equal 40.0+(5/${LATTICE_CONST})
variable        z2_start equal 40.0+(5/5.431)
variable        z2_end   equal ${z2_start}+40.0
variable        z2_end   equal 40.9206407659731+40.0
variable        z_total  equal ${z2_end}
variable        z_total  equal 80.9206407659731

region          sim_box block 0 10 0 10 0 ${z_total}
region          sim_box block 0 10 0 10 0 80.9206407659731
create_box      2 sim_box
Created orthogonal box = (0.0000000 0.0000000 0.0000000) to (54.310000 54.310000 439.48000)
  1 by 1 by 10 MPI processor grid

region          reg_left  block 0 10 0 10 0 40.0
region          reg_right block 0 10 0 10 ${z2_start} ${z2_end}
region          reg_right block 0 10 0 10 40.9206407659731 ${z2_end}
region          reg_right block 0 10 0 10 40.9206407659731 80.9206407659731

create_atoms    1 region reg_left
Created 32200 atoms
  using lattice units in orthogonal box = (0.0000000 0.0000000 0.0000000) to (54.310000 54.310000 439.48000)
  create_atoms CPU = 0.001 seconds
create_atoms    2 region reg_right
Created 32000 atoms
  using lattice units in orthogonal box = (0.0000000 0.0000000 0.0000000) to (54.310000 54.310000 439.48000)
  create_atoms CPU = 0.001 seconds

mass            1 ${M1}
mass            1 28.0855
mass            2 ${M2}
mass            2 28.0855

group           left_block  type 1
32200 atoms in group left_block
group           right_block type 2
32000 atoms in group right_block
group           all_atoms   union left_block right_block
64200 atoms in group all_atoms

variable        Lz_solid equal 40.0*${LATTICE_CONST}
variable        Lz_solid equal 40.0*5.431
variable        Lz_final equal ${z_total}*${LATTICE_CONST}
variable        Lz_final equal 80.9206407659731*${LATTICE_CONST}
variable        Lz_final equal 80.9206407659731*5.431

# --- 5. Potential Definition ---
if "${LATTICE_TYPE} == diamond" then   "pair_style sw"   "pair_coeff * * ${POT_FILE} Si Si"
pair_style sw
pair_coeff * * ${POT_FILE} Si Si
pair_coeff * * Si.sw Si Si
Reading sw potential file Si.sw with DATE: 2007-06-11
if "${MAT_SETUP} == Au_Au" then   "pair_style eam/alloy"   "pair_coeff * * ${POT_FILE} Au Au"
if "${MAT_SETUP} == Si_Pt" then   "pair_style eam/alloy"   "pair_coeff * * ${POT_FILE} Si Pt"

# --- 6. Energy Minimization (CRITICAL STEP) ---
print "Starting Energy Minimization..."
Starting Energy Minimization...
minimize        1.0e-6 1.0e-8 1000 10000
