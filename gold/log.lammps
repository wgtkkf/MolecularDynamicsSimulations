# LAMMPS input script for thermal conductance between gold interfaces at 300 K

# Initialization
units       metal              # Use metal units (appropriate for metallic systems)
dimension   3                  # 3D simulation
boundary    p p p              # Periodic boundary conditions in all directions
atom_style  atomic             # Atomic style for classical simulation

# Create simulation box and atoms
lattice     fcc 4.08           # FCC lattice structure for Gold (Au) with a lattice constant of 4.08 Å
Lattice spacing in x,y,z = 4.0800000 4.0800000 4.0800000
region      box block 0 10 0 10 0 10  # Create a box of size 10x10x10 (in lattice units)
create_box  1 box              # Create simulation box for 1 atom type (Au)
